<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bitejiuyeke.biteadminservice.map.mapper.RegionMapper">

    <!--查询全部区划信息-->
    <select id="selectAllReigon" resultType="com.bitejiuyeke.biteadminservice.map.domain.entity.SysRegion">
        select id,
               code,
               parent_code,
               parent_id,
               name,
               full_name,
               pinyin,
               level,
               longitude,
               latitude
        from sys_region
        order by pinyin
    </select>

    <!--查询下级行政区划信息-->
    <select id="selectRegionChildren" resultType="com.bitejiuyeke.biteadminservice.map.domain.entity.SysRegion">
        select id,
               code,
               parent_code,
               parent_id,
               name,
               full_name,
               pinyin,
               level,
               longitude,
               latitude
        from sys_region
        where parent_id = #{parentId}
        order by pinyin
    </select>


</mapper>